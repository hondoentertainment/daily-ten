VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
# Optional: stable canonical host (no trailing slash). Build injects canonical + og:url.
# On Vercel builds, if unset, vite.config uses VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
# VITE_SITE_URL=https://your-app.vercel.app

# Optional Playwright auth E2E (set before `npm run build` at repo root so Vite embeds VITE_*)
# E2E_AUTH_EMAIL=test@example.com
# E2E_AUTH_PASSWORD=your_test_user_password
