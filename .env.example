# Copy to .env for local scripts (never commit real secrets).

# Supabase project (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Server-side / Edge Functions only — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: invoke Edge Functions locally or in CI
# SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# After linking: npx supabase db push && npx supabase functions deploy ...
# Admin + Studio steps: see supabase/ADMIN_WORKFLOW.md
